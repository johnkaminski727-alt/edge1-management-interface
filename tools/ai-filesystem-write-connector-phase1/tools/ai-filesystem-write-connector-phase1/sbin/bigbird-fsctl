#!/usr/bin/env python3
"""Phase 1 docs-only filesystem staging controller for Edge1.

This command intentionally implements a narrow filesystem write lifecycle:
stage, inspect, diff, approve, apply, status, audit, and rollback.

Phase 1 is limited by policy to documentation paths under
/opt/edge1-management-interface/docs.
"""

from __future__ import annotations

import argparse
import difflib
import hashlib
import json
import os
import re
import shutil
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path, PurePosixPath
from typing import Any


DEFAULT_POLICY = Path("/etc/bigbird-fsctl/policy.json")
ENV_POLICY = "BIGBIRD_FSCTL_POLICY"
ENV_NONROOT = "BIGBIRD_FSCTL_ALLOW_NONROOT"


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def epoch_now() -> int:
    return int(time.time())


def sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def load_policy() -> dict[str, Any]:
    path = Path(os.environ.get(ENV_POLICY, str(DEFAULT_POLICY)))
    if not path.exists():
        raise SystemExit(f"policy not found: {path}")
    return json.loads(path.read_text(encoding="utf-8"))


def as_path(value: str) -> Path:
    return Path(value).expanduser().resolve()


def ensure_root(operation: str, required: bool) -> None:
    if not required:
        return
    if os.environ.get(ENV_NONROOT) == "1":
        return
    if hasattr(os, "geteuid") and os.geteuid() != 0:
        raise SystemExit(f"{operation} requires root")


def normalize_target(raw: str) -> PurePosixPath:
    if "\x00" in raw:
        raise SystemExit("target contains NUL byte")
    target = PurePosixPath(raw)
    if not target.is_absolute():
        raise SystemExit("target must be absolute")
    normalized = PurePosixPath("/") / target.relative_to("/")
    if ".." in normalized.parts:
        raise SystemExit("target must not contain '..'")
    return normalized


def find_allowed_root(policy: dict[str, Any], target: PurePosixPath) -> dict[str, Any]:
    target_text = str(target)
    lowered = f"{target_text.lower()}/"
    for fragment in policy["forbidden_path_fragments"]:
        if fragment.lower() in lowered:
            raise SystemExit(f"target contains forbidden path fragment: {fragment}")
    for root in policy["allowed_roots"]:
        root_path = PurePosixPath(root["path"])
        if target == root_path or root_path in target.parents:
            suffix = Path(target.name).suffix
            if suffix not in root["allowed_extensions"]:
                raise SystemExit(f"extension {suffix!r} is not allowed for {root['label']}")
            return root
    raise SystemExit(f"target is outside allowed roots: {target_text}")


def scan_content(policy: dict[str, Any], content: bytes) -> list[str]:
    text = content.decode("utf-8", errors="ignore")
    findings: list[str] = []
    for pattern in policy.get("secret_patterns", []):
        if re.search(pattern, text):
            findings.append(pattern)
    return findings


def staging_root(policy: dict[str, Any]) -> Path:
    return as_path(policy["staging_root"])


def backup_root(policy: dict[str, Any]) -> Path:
    return as_path(policy["backup_root"])


def audit_log(policy: dict[str, Any]) -> Path:
    return as_path(policy["audit_log"])


def stage_dir(policy: dict[str, Any], stage_id: str) -> Path:
    return staging_root(policy) / stage_id


def metadata_path(policy: dict[str, Any], stage_id: str) -> Path:
    return stage_dir(policy, stage_id) / "metadata.json"


def proposed_path(policy: dict[str, Any], stage_id: str) -> Path:
    return stage_dir(policy, stage_id) / "proposed"


def load_stage(policy: dict[str, Any], stage_id: str) -> dict[str, Any]:
    path = metadata_path(policy, stage_id)
    if not path.exists():
        raise SystemExit(f"unknown stage id: {stage_id}")
    return json.loads(path.read_text(encoding="utf-8"))


def save_stage(policy: dict[str, Any], data: dict[str, Any]) -> None:
    metadata_path(policy, data["stage_id"]).write_text(
        json.dumps(data, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )


def append_audit(policy: dict[str, Any], event: dict[str, Any]) -> None:
    path = audit_log(policy)
    path.parent.mkdir(parents=True, exist_ok=True)
    record = {
        "at": utc_now(),
        "server": policy["server_name"],
        **event,
    }
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, sort_keys=True) + "\n")


def assert_stage_fresh(metadata: dict[str, Any]) -> None:
    if metadata.get("expires_at_epoch") and epoch_now() > int(metadata["expires_at_epoch"]):
        raise SystemExit("stage has expired")


def cmd_init(_: argparse.Namespace) -> None:
    policy = load_policy()
    staging_root(policy).mkdir(parents=True, exist_ok=True)
    backup_root(policy).mkdir(parents=True, exist_ok=True)
    audit_log(policy).parent.mkdir(parents=True, exist_ok=True)
    append_audit(policy, {"event_type": "fs.init", "actor": "operator"})
    print(json.dumps({"status": "initialized", "policy_version": policy["version"]}, indent=2))


def cmd_stage(args: argparse.Namespace) -> None:
    policy = load_policy()
    target = normalize_target(args.target)
    root = find_allowed_root(policy, target)
    source = Path(args.source).resolve()
    content = source.read_bytes()
    if len(content) > int(root["max_bytes"]):
        raise SystemExit("source exceeds policy max_bytes")
    findings = scan_content(policy, content)
    if findings:
        raise SystemExit("secret-pattern scan failed: " + ", ".join(findings))

    target_path = Path(str(target))
    current = target_path.read_bytes() if target_path.exists() else b""
    stage_id = f"{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}-{sha256_bytes(content)[:12]}"
    directory = stage_dir(policy, stage_id)
    directory.mkdir(parents=True, exist_ok=False)
    proposed_path(policy, stage_id).write_bytes(content)

    metadata = {
        "stage_id": stage_id,
        "status": "staged",
        "actor": args.actor,
        "reason": args.reason,
        "created_at": utc_now(),
        "created_at_epoch": epoch_now(),
        "expires_at_epoch": epoch_now() + int(policy["stage_ttl_seconds"]),
        "target": str(target),
        "allowed_root": root["label"],
        "source": str(source),
        "bytes": len(content),
        "current_exists": target_path.exists(),
        "current_sha256": sha256_bytes(current) if target_path.exists() else None,
        "proposed_sha256": sha256_bytes(content),
        "approval_required": bool(policy["require_approval"]),
        "approved_by": None,
        "approved_at": None,
        "applied_at": None,
        "backup_path": None,
        "rolled_back_at": None,
        "scan_status": "passed",
    }
    save_stage(policy, metadata)
    append_audit(
        policy,
        {
            "event_type": "fs.stage",
            "actor": args.actor,
            "stage_id": stage_id,
            "target": str(target),
            "proposed_sha256": metadata["proposed_sha256"],
            "reason": args.reason,
        },
    )
    print(json.dumps({"status": "staged", "stage_id": stage_id, "target": str(target)}, indent=2))


def cmd_inspect(args: argparse.Namespace) -> None:
    policy = load_policy()
    metadata = load_stage(policy, args.stage_id)
    append_audit(policy, {"event_type": "fs.inspect", "actor": args.actor, "stage_id": args.stage_id})
    print(json.dumps(metadata, indent=2, sort_keys=True))


def cmd_status(args: argparse.Namespace) -> None:
    policy = load_policy()
    metadata = load_stage(policy, args.stage_id)
    print(json.dumps({
        "stage_id": args.stage_id,
        "status": metadata["status"],
        "target": metadata["target"],
        "approved_by": metadata.get("approved_by"),
        "applied_at": metadata.get("applied_at"),
        "rolled_back_at": metadata.get("rolled_back_at"),
    }, indent=2, sort_keys=True))


def cmd_diff(args: argparse.Namespace) -> None:
    policy = load_policy()
    metadata = load_stage(policy, args.stage_id)
    target = Path(metadata["target"])
    current = target.read_text(encoding="utf-8").splitlines(keepends=True) if target.exists() else []
    proposed = proposed_path(policy, args.stage_id).read_text(encoding="utf-8").splitlines(keepends=True)
    append_audit(policy, {"event_type": "fs.diff", "actor": args.actor, "stage_id": args.stage_id})
    print("".join(difflib.unified_diff(
        current,
        proposed,
        fromfile=f"running:{metadata['target']}",
        tofile=f"candidate:{metadata['target']}",
    )), end="")


def cmd_approve(args: argparse.Namespace) -> None:
    policy = load_policy()
    ensure_root("approve", bool(policy.get("require_root_for_approve", True)))
    metadata = load_stage(policy, args.stage_id)
    assert_stage_fresh(metadata)
    if metadata["status"] not in {"staged", "approved"}:
        raise SystemExit(f"cannot approve stage in status {metadata['status']}")
    staged = proposed_path(policy, args.stage_id).read_bytes()
    if sha256_bytes(staged) != metadata["proposed_sha256"]:
        raise SystemExit("staged content hash mismatch")
    metadata["status"] = "approved"
    metadata["approved_by"] = args.by
    metadata["approved_at"] = utc_now()
    save_stage(policy, metadata)
    append_audit(policy, {
        "event_type": "fs.approve",
        "actor": args.by,
        "stage_id": args.stage_id,
        "target": metadata["target"],
    })
    print(json.dumps({"status": "approved", "stage_id": args.stage_id, "approved_by": args.by}, indent=2))


def atomic_write(path: Path, content: bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=str(path.parent))
    try:
        with os.fdopen(fd, "wb") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp_name, path)
    finally:
        if os.path.exists(tmp_name):
            os.unlink(tmp_name)


def cmd_apply(args: argparse.Namespace) -> None:
    policy = load_policy()
    ensure_root("apply", bool(policy.get("require_root_for_apply", True)))
    metadata = load_stage(policy, args.stage_id)
    assert_stage_fresh(metadata)
    if policy["require_approval"] and metadata["status"] != "approved":
        raise SystemExit("stage must be approved before apply")
    target = normalize_target(metadata["target"])
    find_allowed_root(policy, target)
    target_path = Path(str(target))
    content = proposed_path(policy, args.stage_id).read_bytes()
    if sha256_bytes(content) != metadata["proposed_sha256"]:
        raise SystemExit("staged content hash mismatch")

    append_audit(policy, {"event_type": "fs.apply_started", "actor": "root-apply-processor", "stage_id": args.stage_id, "target": str(target)})
    backup_dir = backup_root(policy) / args.stage_id
    backup_dir.mkdir(parents=True, exist_ok=True)
    backup_file = backup_dir / "previous"
    marker = backup_dir / "target_missing"
    if target_path.exists():
        shutil.copy2(target_path, backup_file)
    else:
        marker.write_text("target did not exist before apply\n", encoding="utf-8")

    atomic_write(target_path, content)
    written_hash = sha256_bytes(target_path.read_bytes())
    if written_hash != metadata["proposed_sha256"]:
        append_audit(policy, {"event_type": "fs.apply_failed", "actor": "root-apply-processor", "stage_id": args.stage_id, "target": str(target), "error": "written hash mismatch"})
        raise SystemExit("post-apply verification failed")

    metadata["status"] = "applied"
    metadata["applied_at"] = utc_now()
    metadata["backup_path"] = str(backup_file) if backup_file.exists() else str(marker)
    save_stage(policy, metadata)
    append_audit(policy, {
        "event_type": "fs.apply_succeeded",
        "actor": "root-apply-processor",
        "stage_id": args.stage_id,
        "target": str(target),
        "written_sha256": written_hash,
        "backup_path": metadata["backup_path"],
    })
    print(json.dumps({"status": "applied", "stage_id": args.stage_id, "verified_sha256": written_hash}, indent=2))


def cmd_rollback(args: argparse.Namespace) -> None:
    policy = load_policy()
    ensure_root("rollback", bool(policy.get("require_root_for_apply", True)))
    metadata = load_stage(policy, args.stage_id)
    if metadata["status"] != "applied":
        raise SystemExit("only applied stages can be rolled back")
    target = normalize_target(metadata["target"])
    find_allowed_root(policy, target)
    target_path = Path(str(target))
    backup = Path(metadata["backup_path"]) if metadata.get("backup_path") else None
    append_audit(policy, {"event_type": "fs.rollback_started", "actor": args.by, "stage_id": args.stage_id, "target": str(target)})
    if backup and backup.name == "previous" and backup.exists():
        atomic_write(target_path, backup.read_bytes())
    elif backup and backup.name == "target_missing":
        if target_path.exists():
            target_path.unlink()
    else:
        append_audit(policy, {"event_type": "fs.rollback_failed", "actor": args.by, "stage_id": args.stage_id, "target": str(target), "error": "backup missing"})
        raise SystemExit("backup missing")
    metadata["status"] = "rolled_back"
    metadata["rolled_back_at"] = utc_now()
    save_stage(policy, metadata)
    append_audit(policy, {"event_type": "fs.rollback_succeeded", "actor": args.by, "stage_id": args.stage_id, "target": str(target)})
    print(json.dumps({"status": "rolled_back", "stage_id": args.stage_id}, indent=2))


def cmd_audit(args: argparse.Namespace) -> None:
    policy = load_policy()
    path = audit_log(policy)
    if not path.exists():
        return
    lines = path.read_text(encoding="utf-8").splitlines()
    for line in lines[-args.limit:]:
        print(line)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Edge1 Phase 1 docs-only filesystem staging controller")
    sub = parser.add_subparsers(dest="command", required=True)

    init = sub.add_parser("init")
    init.set_defaults(func=cmd_init)

    stage = sub.add_parser("stage")
    stage.add_argument("--source", required=True)
    stage.add_argument("--target", required=True)
    stage.add_argument("--actor", required=True)
    stage.add_argument("--reason", required=True)
    stage.set_defaults(func=cmd_stage)

    inspect = sub.add_parser("inspect")
    inspect.add_argument("stage_id")
    inspect.add_argument("--actor", default="operator")
    inspect.set_defaults(func=cmd_inspect)

    status = sub.add_parser("status")
    status.add_argument("stage_id")
    status.set_defaults(func=cmd_status)

    diff = sub.add_parser("diff")
    diff.add_argument("stage_id")
    diff.add_argument("--actor", default="operator")
    diff.set_defaults(func=cmd_diff)

    approve = sub.add_parser("approve")
    approve.add_argument("--by", required=True)
    approve.add_argument("stage_id")
    approve.set_defaults(func=cmd_approve)

    apply = sub.add_parser("apply")
    apply.add_argument("stage_id")
    apply.set_defaults(func=cmd_apply)

    rollback = sub.add_parser("rollback")
    rollback.add_argument("--by", required=True)
    rollback.add_argument("stage_id")
    rollback.set_defaults(func=cmd_rollback)

    audit = sub.add_parser("audit")
    audit.add_argument("--limit", type=int, default=20)
    audit.set_defaults(func=cmd_audit)
    return parser


def main() -> None:
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
