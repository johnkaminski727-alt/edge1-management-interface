{
  "version": "phase1-docs-only",
  "server_name": "edge1",
  "staging_root": "/var/lib/bigbird-fsctl/staging",
  "backup_root": "/var/lib/bigbird-fsctl/backups",
  "audit_log": "/var/log/bigbird-fsctl/audit.jsonl",
  "require_root_for_approve": true,
  "require_root_for_apply": true,
  "require_approval": true,
  "stage_ttl_seconds": 86400,
  "allowed_roots": [
    {
      "label": "management-interface-docs",
      "path": "/opt/edge1-management-interface/docs",
      "max_bytes": 250000,
      "allowed_extensions": [
        ".json",
        ".md",
        ".txt",
        ".yaml",
        ".yml"
      ]
    }
  ],
  "forbidden_path_fragments": [
    "/.ssh/",
    "/.gnupg/",
    "/credentials/",
    "/private_keys/",
    "/secrets/",
    "/shadow",
    "/passwd"
  ],
  "secret_patterns": [
    "BEGIN OPENSSH PRIVATE KEY",
    "BEGIN RSA PRIVATE KEY",
    "BEGIN EC PRIVATE KEY",
    "BEGIN PRIVATE KEY",
    "AKIA[0-9A-Z]{16}",
    "sk_live_[A-Za-z0-9]+",
    "xox[baprs]-[A-Za-z0-9-]+"
  ]
}
