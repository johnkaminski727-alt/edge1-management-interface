{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ww.cx/schemas/telegraph-envelope.schema.json",
  "title": "WW.CX Telegraph Federation Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "message_id",
    "created_at",
    "origin",
    "destination",
    "payload",
    "security",
    "signature"
  ],
  "properties": {
    "version": {"const": "1.0"},
    "message_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{16,128}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "origin": {"$ref": "#/$defs/address"},
    "destination": {"$ref": "#/$defs/address"},
    "route": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/hop"}
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_type", "encoding", "ciphertext"],
      "properties": {
        "content_type": {"type": "string", "minLength": 1, "maxLength": 127},
        "encoding": {"enum": ["base64url"]},
        "ciphertext": {"type": "string", "minLength": 1, "maxLength": 16777216},
        "detached_attachments": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["digest", "size"],
            "properties": {
              "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
              "size": {"type": "integer", "minimum": 0, "maximum": 1073741824}
            }
          }
        }
      }
    },
    "security": {"$ref": "#/$defs/security"},
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {"enum": ["Ed25519"]},
        "key_id": {"type": "string", "minLength": 8, "maxLength": 255},
        "value": {"type": "string", "minLength": 32, "maxLength": 1024}
      }
    }
  },
  "$defs": {
    "address": {
      "type": "object",
      "additionalProperties": false,
      "required": ["office", "endpoint"],
      "properties": {
        "office": {"type": "string", "pattern": "^[a-z0-9.-]{3,253}$"},
        "endpoint": {"type": "string", "minLength": 1, "maxLength": 255}
      }
    },
    "hop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["office", "received_at"],
      "properties": {
        "office": {"type": "string", "pattern": "^[a-z0-9.-]{3,253}$"},
        "received_at": {"type": "string", "format": "date-time"},
        "transport": {"enum": ["https-mtls", "private-wan", "test-loopback"]}
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "content_encryption", "key_visibility", "downgrades"],
      "properties": {
        "state": {
          "enum": [
            "end_to_end_encrypted",
            "gateway_decrypted",
            "relay_accessible",
            "transport_encrypted_only",
            "plaintext_test"
          ]
        },
        "content_encryption": {"enum": ["XChaCha20-Poly1305", "AES-256-GCM", "none"]},
        "key_visibility": {"enum": ["endpoints_only", "gateway", "relay_operator", "server", "none"]},
        "forward_secrecy": {"type": "boolean"},
        "downgrades": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "legacy_tty_conversion",
              "human_relay",
              "server_side_transformation",
              "plaintext_archival",
              "endpoint_key_escrow",
              "unsupported_peer",
              "test_mode"
            ]
          }
        }
      }
    }
  }
}
