[Unit]
Description=WW.CX Operations Center automation health exporter
After=network-online.target

[Service]
Type=oneshot
User=root
ExecStart=/usr/bin/python3 /opt/edge1-management-interface/server/operations_automation_health_exporter.py
ReadWritePaths=/var/www/edge1-status
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
