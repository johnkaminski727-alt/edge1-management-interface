[Unit]
Description=Edge1 Autonomous Operator MCP Service
After=network.target

[Service]
Type=simple
User=edge1-operator
WorkingDirectory=/opt/edge1-operator
EnvironmentFile=/etc/edge1-operator/edge1-operator.env
ExecStart=/usr/bin/python3 -m server.edge1_operator_entrypoint
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
