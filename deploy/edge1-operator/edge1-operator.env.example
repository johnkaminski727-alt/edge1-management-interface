# Edge1 Operator configuration template
# Copy outside the repository and protect with appropriate permissions.

EDGE1_OPERATOR_EVIDENCE=/var/lib/edge1-operator/evidence
EDGE1_OPERATOR_ROOTS=/opt
EDGE1_OPERATOR_BIND=127.0.0.1
EDGE1_OPERATOR_PORT=8095

# Authentication material must be provisioned outside Git.
# EDGE1_OPERATOR_TOKEN_FILE=/etc/edge1-operator/token
