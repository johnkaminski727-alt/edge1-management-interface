+def run_fsctl(args: list[str], input_text: str | None = None) -> subprocess.CompletedProcess[str]:
+    if not FS_MCP_ENABLED:
+        raise RuntimeError("Filesystem MCP bridge is disabled")
+    if not FSCTL.is_file():
+        raise RuntimeError("bigbird-fsctl is not installed")
+    return subprocess.run(
+        [str(FSCTL), *args],
+        input=input_text,
+        text=True,
+        capture_output=True,
+        timeout=15,
+        check=False,
+    )
+
+
+def parse_json_output(proc: subprocess.CompletedProcess[str]) -> dict[str, Any]:
+    if proc.returncode != 0:
+        raise RuntimeError((proc.stderr or proc.stdout or "fsctl command failed")[:1200])
+    try:
+        return json.loads(proc.stdout)
+    except json.JSONDecodeError:
+        return {"text": proc.stdout}
+
+
+@mcp.tool(
+    name="bigbird.fs.stage",
+    title="Stage filesystem proposal",
+    description=(
+        "Stage a docs-only filesystem proposal through bigbird-fsctl. "
+        "This cannot approve, apply, or roll back changes; operator shell approval remains mandatory."
+    ),
+    annotations=BOUNDED_WRITE,
+    structured_output=True,
+)
+def fs_stage(
+    target: str = Field(pattern=r"^/opt/edge1-management-interface/docs/[A-Za-z0-9._/\-]+$"),
+    content: str = Field(min_length=1, max_length=200000),
+    actor: str = Field(default="mcp", min_length=1, max_length=80),
+    reason: str = Field(min_length=3, max_length=240),
+) -> dict[str, Any]:
+    if contains_secret(content) or contains_secret(reason):
+        raise ValueError("Filesystem proposal appears to contain sensitive credentials")
+    with tempfile.NamedTemporaryFile("w", encoding="utf-8", prefix="bigbird-fs-stage-", suffix=".md", delete=False) as handle:
+        handle.write(content)
+        source = handle.name
+    try:
+        result = parse_json_output(run_fsctl([
+            "stage",
+            "--source", source,
+            "--target", target,
+            "--actor", actor,
+            "--reason", reason,
+        ]))
+    finally:
+        try:
+            Path(source).unlink()
+        except FileNotFoundError:
+            pass
+    audit("mcp_fs_staged", {"stage_id": result.get("stage_id"), "target": target})
+    return {
+        "version": APP_VERSION,
+        "enabled": FS_MCP_ENABLED,
+        "status": result.get("status", "staged"),
+        "stage": result,
+        "next_step": "Operator must inspect/diff, approve with sudo bigbird-fsctl approve --by <name>, then apply from shell.",
+    }
+
+
+@mcp.tool(
+    name="bigbird.fs.status",
+    title="Read filesystem stage status",
+    description="Read one bigbird-fsctl stage status without changing it.",
+    annotations=READ_ONLY,
+    structured_output=True,
+)
+def fs_status(stage_id: str = Field(pattern=r"^[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$")) -> dict[str, Any]:
+    result = parse_json_output(run_fsctl(["status", stage_id]))
+    audit("mcp_fs_status", {"stage_id": stage_id, "found": bool(result)})
+    return {"version": APP_VERSION, "stage": result}
+
+
+@mcp.tool(
+    name="bigbird.fs.diff",
+    title="Read filesystem stage diff",
+    description="Read one bigbird-fsctl stage diff without changing it.",
+    annotations=READ_ONLY,
+    structured_output=True,
+)
+def fs_diff(stage_id: str = Field(pattern=r"^[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$")) -> dict[str, Any]:
+    proc = run_fsctl(["diff", stage_id, "--actor", "mcp"])
+    if proc.returncode != 0:
+        raise RuntimeError((proc.stderr or proc.stdout or "fsctl diff failed")[:1200])
+    audit("mcp_fs_diff", {"stage_id": stage_id, "chars": len(proc.stdout)})
+    return {"version": APP_VERSION, "stage_id": stage_id, "diff": proc.stdout}
+
+
+@mcp.tool(
+    name="bigbird.fs.audit",
+    title="Read filesystem connector audit",
+    description="Read recent bigbird-fsctl audit events.",
+    annotations=READ_ONLY,
+    structured_output=True,
+)
+def fs_audit(limit: int = Field(default=20, ge=1, le=100)) -> dict[str, Any]:
+    result = parse_json_output(run_fsctl(["audit", "--limit", str(limit)]))
+    audit("mcp_fs_audit", {"limit": limit})
+    return {"version": APP_VERSION, "audit": result}
+
+
 if __name__ == "__main__":
     mcp.run(transport="stdio")

