# Internal messaging management API. Keep bound to a private or loopback interface.
WWCX_MESSAGING_BASE_URL=http://127.0.0.1:58080

# Read-only status credential. Store the real value outside Git.
WWCX_MESSAGING_READ_TOKEN=replace-with-read-token

# Control remains disabled until an approved activation change.
WWCX_MESSAGING_CONTROL_ENABLED=false
WWCX_MESSAGING_CONTROL_TOKEN=
