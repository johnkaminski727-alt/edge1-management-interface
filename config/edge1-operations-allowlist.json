{
  "version": 1,
  "actions": {
    "repository.status": {
      "argv": [
        "git",
        "status",
        "--short",
        "--branch"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "repository.fetch": {
      "argv": [
        "git",
        "fetch",
        "--prune",
        "origin"
      ],
      "mutating": true,
      "timeout_seconds": 120
    },
    "repository.fast_forward_main": {
      "argv": [
        "git",
        "pull",
        "--ff-only",
        "origin",
        "main"
      ],
      "mutating": true,
      "timeout_seconds": 180
    },
    "validation.interconnect": {
      "argv": [
        "sh",
        "deploy/interconnect/validate-staging-assets.sh"
      ],
      "mutating": false,
      "timeout_seconds": 300
    },
    "validation.numbering_node": {
      "argv": [
        "python3",
        "-m",
        "unittest",
        "discover",
        "-s",
        "tests",
        "-p",
        "test_wwcx_numbering_node.py",
        "-v"
      ],
      "mutating": false,
      "timeout_seconds": 300
    },
    "numbering.health": {
      "argv": [
        "curl",
        "-fsS",
        "http://127.0.0.1:8093/healthz"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "telephony.health": {
      "argv": [
        "curl",
        "-fsS",
        "http://127.0.0.1:8096/api/telephony/status"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "bigbird.health": {
      "argv": [
        "curl",
        "-fsS",
        "http://127.0.0.1:8787/v1/health"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "bigbird.tools": {
      "argv": [
        "curl",
        "-fsS",
        "http://127.0.0.1:8787/v1/tools"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "messaging.health": {
      "argv": [
        "curl",
        "-fsS",
        "http://127.0.0.1:58080/healthz"
      ],
      "mutating": false,
      "timeout_seconds": 30
    },
    "time_authority.summary": {
      "argv": [
        "python3",
        "server/time_authority_summary.py"
      ],
      "mutating": false,
      "timeout_seconds": 30
    }
  }
}
