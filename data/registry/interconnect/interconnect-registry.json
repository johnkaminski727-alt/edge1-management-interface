      "codecs": [
        "PCMU",
        "PCMA"
      ],
      "health_check": "options"
    }
  ],
  "routing_rules": [
    {
      "id": "default-lab-route",
      "match": "+*",
      "destination": "edge1-lab-peer",
      "priority": 100
    }
  ]
}
